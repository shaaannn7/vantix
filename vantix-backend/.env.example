# Vantix Backend API Service — Environment Variables Config Example
# Copy this file to '.env' inside the 'vantix-backend' directory for local development override.

# 1. Google Gemini API Key (Required for active GenAI operations workflows)
# If missing, the backend degrades gracefully to mock mock/deterministic decisions mode.
GEMINI_API_KEY=AIzaSy...

# 2. Host Execution Port (Default: 8080)
PORT=8080
