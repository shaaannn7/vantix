# Ventix Stadium Operations Console — Environment Variables Config Example
# Copy this file to '.env' inside the 'ventix-frontend' directory for local development override.

# 1. API Backend REST Base URL
VITE_API_BASE_URL=http://localhost:8080/api

# 2. Operations & Telemetry WebSocket Endpoint URL
VITE_WS_TELEMETRY_URL=ws://localhost:8080/ws/operations

# 3. Mapbox GL API Access Token (For regional/transport layout map projections)
VITE_MAPBOX_ACCESS_TOKEN=mock_mapbox_token

# 4. Simulation Engine Engine Override (true/false)
VITE_SIMULATION_MODE=true
